generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  role           String          @default("USER") // USER, ADMIN
  refreshToken   String?
  lastLoginAt    DateTime?
  isActive       Boolean         @default(true)
  suspendedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  projects       Project[]
  promptHistory  PromptHistory[]
  generations    Generation[]
  exportHistory  ExportHistory[]
  auditLogs      AuditLog[]
  loginHistory   LoginHistory[]
  twoFactorCodes AdminTwoFactorCode[]
}

model Project {
  id            String           @id @default(cuid())
  name          String
  prompt        String?          @db.Text
  code          String?          @db.Text
  aiProvider    String           @default("groq")
  language      String           @default("react") // react, html
  isPublic      Boolean          @default(false)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      ProjectVersion[]
  promptHistory PromptHistory[]
  generations   Generation[]
  exportHistory ExportHistory[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
}

model ProjectVersion {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version    Int
  prompt     String?  @db.Text
  code       String?  @db.Text
  aiProvider String   @default("groq")
  createdAt  DateTime @default(now())

  @@index([projectId])
}

model PromptHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  prompt     String   @db.Text
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([projectId])
}

model Generation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  provider   String
  tokensUsed Int?
  durationMs Int
  status     String   // SUCCESS, FAILED
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([projectId])
}

model ExportHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  format    String   // ZIP, CODE
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  code        String   @db.Text
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String
  metadata  String?  @db.Text // JSON metadata
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model HealthCheck {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  failureReason String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ProviderStats {
  id            String   @id @default(cuid())
  provider      String   // gemini, openai, anthropic, etc.
  totalRequests Int      @default(0)
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  avgResponseTime Float  @default(0)
  lastUsedAt    DateTime?
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider])
}

model AppSettings {
  id                  String   @id @default(cuid())
  appName             String   @default("Cognify-AI")
  logoUrl             String?
  theme               String   @default("dark")
  defaultAIProvider   String   @default("groq")
  defaultFramework    String   @default("react")
  generationLimit     Int      @default(100)
  promptLimit         Int      @default(1000)
  exportLimit         Int      @default(50)
  sessionTimeout      Int      @default(30)
  maintenanceMode     Boolean  @default(false)
  maintenanceMessage  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SystemMetrics {
  id            String   @id @default(cuid())
  cpuUsage      Float
  memoryUsage   Float
  diskUsage     Float
  uptime        Int
  nodeVersion   String
  environment   String
  databaseStatus String
  apiStatus     String
  frontendStatus String
  backendStatus String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model AdminTwoFactorCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String   // bcrypt hash of the 6-digit code — never stored plaintext
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
